# ─────────────────────────────────────────────────────────────
# Score Guru — Environment Variables
# Copy to .env.local for local dev. Set the same vars in Vercel.
# ─────────────────────────────────────────────────────────────

# Public (safe to expose to the browser) — anon key, RLS allows SELECT only.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only (NEVER prefixed with NEXT_PUBLIC). Holds full write access.
# Found in: Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Admin login. A single password, verified server-side.
ADMIN_PASSWORD=change-me-to-a-strong-password

# Secret used to sign the httpOnly admin session cookie (JWT).
# Generate with:  openssl rand -base64 48
SESSION_SECRET=generate-a-long-random-string-at-least-32-chars
